# Nexus API Server Configuration

# Server port
NEXUS_PORT=8090

# JWT Secret for issuing/validating Nexus tokens (shared with your console)
NEXUS_JWT_SECRET=change-me-to-a-random-string

# GitHub Configuration
# Personal Access Token with repo+workflow scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub repo that has the build workflows (your fork of rustdesk-generator)
GITHUB_OWNER=your-github-username
GITHUB_REPO=rustdesk-generator

# Workflow filename prefix — nexus appends -<os>.yml (e.g. build-custom-windows.yml, build-custom-android.yml)
GITHUB_WORKFLOW_PREFIX=build-custom

# RustDesk source repo to build from (your fork)
RUSTDESK_REPO=your-github-username/rustdesk
RUSTDESK_REF=refs/tags/1.4.9

# Storage path for downloaded builds
NEXUS_STORAGE_PATH=./artifacts

# Build limits per month per user (0 = unlimited)
NEXUS_MAX_BUILDS_PER_MONTH=15

# Public URL where this server is reachable (for GitHub Actions artifact download)
# Leave empty to download from GitHub directly
NEXUS_PUBLIC_URL=

# GitHub App ID for authentication (optional, alternative to PAT)
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
